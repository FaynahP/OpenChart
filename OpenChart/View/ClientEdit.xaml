<Window x:Class="OpenChart.View.EDIT.ClientEdit"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenChart.View.EDIT"
        mc:Ignorable="d"
        Title="ClientEdit" Height="450" Width="800">
    <Window.Background>
        <SolidColorBrush Color="#f0f2f2"/>
    </Window.Background>
    <Viewbox Stretch="Uniform">
        <Grid Margin="0,0,0,62">
            <Grid.RowDefinitions>
                <RowDefinition Height="29*"/>
                <RowDefinition Height="31*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="191*"/>
                <ColumnDefinition Width="809*"/>
            </Grid.ColumnDefinitions>
            <!--TOP BAR-->
            <Border Background="White" BorderBrush="DimGray" BorderThickness="1" Height="40" Width="1097" VerticalAlignment="Top" Margin="-9,-5.5,0,0" Grid.Column="1">
                <Button  Height="20" Width="50" FontFamily="Gill Sans MT" FontWeight="Regular" HorizontalAlignment="Right" Margin="10,0,10,0" Background="{x:Null}" BorderBrush="{x:Null}">
                    <TextBlock Text="Logout" TextDecorations="Underline" FontSize="15" FontFamily="Gill Sans MT Condensed" FontWeight="Regular" HorizontalAlignment="Right" Margin="0,0,0,0"/>
                </Button>
            </Border>
            <StackPanel HorizontalAlignment="Left" Margin="10,-4.5,0,0" Grid.ColumnSpan="2" Grid.RowSpan="2">
                <Border Background="#9BDBDB" CornerRadius="6" Width="30" Height="30" Margin="0,3,825,-2">
                    <Image Source="/Images/ICONS/OCTempLogo.png" Height="35" Width="30" />
                </Border>
                <TextBlock Text="OpenChart" FontSize="20" FontFamily="Gill Sans MT" FontWeight="Bold" Width="111" Margin="0,-25,675,-2"/>
            </StackPanel>


            <!--NAVIGATION BAR-->
            <Border Background="#dcf4f4" BorderBrush="DimGray" BorderThickness="1" Height="554" Width="150" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="0,0,0,-67" Grid.ColumnSpan="2" Grid.RowSpan="2"/>
            <!--AddButton-->
            <Button Background="#9bdbdb" Height="50" Margin="3,45,953,394" BorderThickness="2" BorderBrush="#43989b" Grid.ColumnSpan="2" >
                <TextBlock Text="QUICK ADD" FontSize="12" FontFamily="Gill Sans MT" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="30,0,0,0"/>
            </Button>
            <Image Source="/Images/ICONS/PLUS.png" Margin="13,66,0,415" Width="15" HorizontalAlignment="Left"  Grid.Column="1"/>


            <!--Dashboard-->
            <Border Background="#54b4b4"  Opacity="0" Height="40" Width="5" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="3,131,0,0"/>
            <StackPanel Grid.ColumnSpan="2" Margin="-59,0,80,10" Grid.RowSpan="2">
                <Image Source="/Images/ICONS/DASHBOARD.png" Height="20" Width="20" Margin="0,140,900,-1"/>
                <TextBlock Text="Dashboard" FontSize="12" FontFamily="Gill Sans MT" FontWeight="UltraBold" Width="70" Height="17"  Margin="0,-15,802,0"/>
                <Button  Command="{Binding DashCommand}" Opacity="0" BorderThickness="0" HorizontalAlignment="Left" Height="40" Width="188.5" Margin="0,-30,0,0">


                </Button>
            </StackPanel>
            <!--Medicine-->
            <StackPanel Grid.ColumnSpan="2" Margin="-59,40,80,10" Grid.RowSpan="2">
                <Image Source="/Images/ICONS/MEDICINE.png" Height="50" Width="25" Margin="0,150,900,-1"/>
                <TextBlock Text="Medicine" FontSize="12" FontFamily="Gill Sans MT" FontWeight="UltraBold"  Width="70" Margin="0,-45,800,0" Height="17"/>
                <Button  Command="{Binding MedicineCommand}" Opacity="0"  BorderThickness="0" HorizontalAlignment="Left" Height="40" Width="190.5" Margin="0,-50,0,0">
                </Button>
            </StackPanel>
            <!--Clients-->
            <StackPanel Grid.ColumnSpan="2" Margin="-59,95,80,10" Grid.RowSpan="2">
                <Image Source="/Images/ICONS/CLIENTS.png" Height="50" Width="25" Margin="0,150,900,-1"/>
                <TextBlock Text="Clients" FontSize="12" FontFamily="Gill Sans MT" FontWeight="UltraBold"  Width="70" Margin="0,-45,800,0" Height="17"/>
                <Button  Command="{Binding ClientCommand}" Opacity="0"  BorderThickness="0" HorizontalAlignment="Left" Height="40" Width="190.5" Margin="0,-50,0,0">

                </Button>
            </StackPanel>
            <!--Transactions-->
            <StackPanel Grid.ColumnSpan="2" Margin="-59,100,80,10" Grid.RowSpan="2">
                <Image Source="/Images/ICONS/REPORTS.png" Height="50" Width="25" Margin="0,203,900,-1"/>
                <TextBlock Text="Transactions" FontSize="12" FontFamily="Gill Sans MT" FontWeight="UltraBold"  Width="72" Margin="2,-45,800,0" Height="17"/>
                <Button  Command="{Binding TransCommand}" Opacity="0"  BorderThickness="0" HorizontalAlignment="Left" Height="40" Width="190.5" Margin="0,-50,0,0">

                </Button>
            </StackPanel>
            <!--Supply Batch-->
            <StackPanel Grid.ColumnSpan="2" Margin="-59,157,80,10" Grid.RowSpan="2">
                <Image Source="/Images/ICONS/SUPPLY BATCH.png" Height="50" Width="25" Margin="0,203,899,-1"/>
                <TextBlock Text="Supply Batch" FontSize="12" FontFamily="Gill Sans MT" FontWeight="UltraBold"  Width="73" Margin="5,-45,800,0" Height="17"/>
                <Button  Command="{Binding SuBCommand}" Opacity="0"  BorderThickness="0" HorizontalAlignment="Left" Height="40" Width="190.5" Margin="0,-50,0,0">

                </Button>
            </StackPanel>
            <!--Suppliers-->
            <StackPanel Grid.ColumnSpan="2" Margin="-59,220,76,10" Grid.RowSpan="2">
                <Image Source="/Images/ICONS/SUPPLIER.png" Height="50" Width="25" Margin="0,203,899,-1"/>
                <TextBlock Text="Suppliers" FontSize="12" FontFamily="Gill Sans MT" FontWeight="UltraBold"  Width="73" Margin="8,-45,800,0" Height="17"/>
                <Button  Command="{Binding SuppCommand}" Opacity="0"  BorderThickness="0" HorizontalAlignment="Left" Height="40" Width="190.5" Margin="0,-50,0,0">

                </Button>
            </StackPanel>
            <Button Height="20" Width="50" FontFamily="Gill Sans MT Condensed" FontWeight="Regular" HorizontalAlignment="Right" Margin="0,26,998,-46" Grid.Column="1" Grid.Row="1" Background="{x:Null}" BorderBrush="{x:Null}">
                <TextBlock Text="Logout" TextDecorations="Underline" FontSize="15" FontFamily="Gill Sans MT Condensed" FontWeight="Regular" HorizontalAlignment="Right" Margin="0,0,0,0"/>
            </Button>
            <Button Height="20" Width="50" FontFamily="Gill Sans MT Condensed" FontWeight="Regular" HorizontalAlignment="Right" Margin="0,26,998,-46" Grid.Column="1" Grid.Row="1" Background="{x:Null}" BorderBrush="{x:Null}">
                <TextBlock Text="Logout" TextDecorations="Underline" FontSize="15" FontFamily="Gill Sans MT Condensed" FontWeight="Regular" HorizontalAlignment="Right" Margin="0,0,0,0"/>
            </Button>


            <!--QUICK ADD CONTENT:CLIENT-->
            <StackPanel  VerticalAlignment="Top" HorizontalAlignment="Left" Grid.Column="1" Margin="370,70,0,0">
                <Border Background="#dcf4f4" Height="451" Width="474" BorderThickness="1" BorderBrush="#aac7c7">
                    <StackPanel>
                        <Border Background="#ebffff" Height= "375" Width="450" Margin="0,60,0,0">
                            <StackPanel Margin="0,-20,0,0">
                                <Border Background="#ebffff" Height= "375" Width="450" Margin="0,30,0,0">
                                    <StackPanel Margin="0,-20,0,0">
                                        <StackPanel Margin="20,10,10,10" HorizontalAlignment="Left">
                                            <TextBlock Text="First Name" FontSize="15" FontFamily="Gill Sans MT" FontWeight="UltraBold" Height="20" Margin="-50,50,0,0" Width="100"/>
                                            <TextBlock Text="Last Name" FontSize="15" FontFamily="Gill Sans MT" FontWeight="UltraBold" Height="20"  Margin="-50,50,0,0" Width="100"/>
                                            <TextBlock Text="Contact No." FontSize="15" FontFamily="Gill Sans MT" FontWeight="UltraBold" Height="20"  Margin="-50,50,0,0" Width="100"/>
                                            <TextBlock Text="Emergency Contact" FontSize="15" FontFamily="Gill Sans MT" FontWeight="UltraBold" Height="20"  Margin="0,50,0,0" Width="150"/>
                                        </StackPanel>
                                        <StackPanel Margin="200,-240,10,10" HorizontalAlignment="Left">
                                            <TextBox Height="20" Width="200"/>
                                            <TextBox Height="20" Width="200" Margin="0,50,0,0"/>
                                            <TextBox Height="20" Width="200" Margin="0,50,0,0"/>
                                            <TextBox Height="20" Width="200" Margin="0,50,0,0"/>
                                        </StackPanel>
                                        <Button Content="SAVE" Height="40" Width="90" HorizontalAlignment="Right" Margin="0,20,160,0" Background="#9bdbdb" BorderThickness="1" BorderBrush="#43989b" FontFamily="Gill Sans MT"  FontWeight="Bold"/>
                                        <Button Content="DELETE" Height="40" Width="90" HorizontalAlignment="Right" Margin="0,-40,50,0" Background="#db9b9b" BorderThickness="1" BorderBrush="#43989b" FontFamily="Gill Sans MT"  FontWeight="Bold"/>
                                    </StackPanel>

                                </Border>
                                <Button Content="ADD SUPPLY" Height="40" Width="90" HorizontalAlignment="Right" Margin="0,10,160,0" Background="#9bdbdb" BorderThickness="1" BorderBrush="#43989b" FontFamily="Gill Sans MT"  FontWeight="Bold"/>
                                <Button Content="CANCEL" Height="40" Width="90" HorizontalAlignment="Right" Margin="0,-40,50,0" Background="#c1f0f0" BorderThickness="1" BorderBrush="#43989b" FontFamily="Gill Sans MT"  FontWeight="Bold"/>
                            </StackPanel>

                        </Border>
                        <Border  Background="#9bdbdb" Height= "45" Width="474" Margin="-1,-825,0,0" BorderThickness="1" BorderBrush="#aac7c7">
                            <Grid>
                                <TextBlock Text="EDIT CLIENT" FontFamily="Century Gothic" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <Button Content="X" FontSize="20" FontFamily="Century Gothic" FontWeight="Bold" Foreground="#0b8a8a" Margin="420,0,0,0" Height="40" Width="20" Background="{x:Null}" BorderBrush="{x:Null}"/>
                            </Grid>
                            
                        </Border>
                     
                    </StackPanel>

                </Border>
            </StackPanel>
        </Grid>
    </Viewbox>
</Window>
