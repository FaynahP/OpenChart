<Window x:Class="OpenChart.View.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenChart.View"
        mc:Ignorable="d"
        Title="Login" Height="450" Width="800">
    <Window.Background>
        <ImageBrush ImageSource="/Images/OCLogIn (1).png" />
    </Window.Background>
    <Viewbox Stretch="Uniform">
        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="387*"/>
                <ColumnDefinition Width="413*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Image Source="/Images/OCTempLogo.png" Width="190" Height="147" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="23,10,0,0"/>
            <StackPanel Margin="-86,136,617,10">
                <TextBlock Text="Username:" FontSize="16" Margin="10" FontFamily="Cascadia Mono" FontWeight="Bold" Foreground="Black" />
                <TextBlock Text="Password:" FontSize="16" Margin="10" FontFamily="Cascadia Mono" FontWeight="Bold" Foreground="Black"/>
            </StackPanel>
            <StackPanel Margin="-15,141,331,82" Grid.RowSpan="3">
                <TextBox x:Name="User" Text="{Binding CurrentUser.Username,UpdateSourceTrigger=PropertyChanged}" Height="30" Width="261"/>
                <PasswordBox x:Name="Passwordbx" Height="30" Margin="10" Width="260"/>
            </StackPanel>
            <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,87" Grid.RowSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
            </Grid>
            <Grid Grid.Row="3" Grid.ColumnSpan="2" Margin="0,87,0,0" Grid.RowSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
            </Grid>


            <Button x:Name="Loginbutton"   Command="{Binding LoginCommand}" CommandParameter="{Binding ElementName=Passwordbx}"  Grid.Row="2" Width="80" FontFamily="Lucida Console" FontWeight="Bold" Margin="78,34,477,82">
                <TextBlock Text="Login" FontSize="15" FontFamily="Lucida Console" FontWeight="Bold" Foreground="Black"/>
                <Button.BorderBrush>
                    <SolidColorBrush Color="Blue" Opacity="100"/>
                </Button.BorderBrush>
                <Button.Background>
                    <SolidColorBrush Color="#51b6b6" Opacity="100"/>
                </Button.Background>
            </Button>
        </Grid>
    </Viewbox>
</Window>
