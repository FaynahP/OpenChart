<Window x:Class="OpenChart.View.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenChart.View"
        mc:Ignorable="d"
        Title="Login" WindowState="Maximized" WindowStyle="SingleBorderWindow" Height="450" Width="800">
    <Window.Background>
        <ImageBrush ImageSource="/Images/BACKGROUNDS/OCLogIn (1).png" />
    </Window.Background>
    <Viewbox Stretch="Uniform">
        <Grid>


            <Image Source="/Images/ICONS/OCTempLogo.png" Width="95" Height="66" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="115,10,0,0"/>
            <TextBlock Text="Username:" Width="90" HorizontalAlignment="Left" FontSize="16" FontFamily="Cascadia Mono" FontWeight="Bold" Foreground="Black" Margin="10,89,0,196" />
            <TextBox x:Name="User" Text="{Binding CurrentUser.UserName, UpdateSourceTrigger=PropertyChanged}" Height="25" Width="200" Margin="115,90,339,226"/>
            <PasswordBox x:Name="Passwordbx" Height="25" Width="200" Margin="115,45,339,97"/>
            <TextBlock Text="Password:" Width="90" HorizontalAlignment="Left" FontSize="16" FontFamily="Cascadia Mono" FontWeight="Bold" Foreground="Black" Margin="10,135,0,150"/>

            <Line X1="0" Y1="0" X2="290" Y2="0"  Stroke="#515151" StrokeThickness="1" Grid.Row="2" Margin="14,240,0,0"/>
            <Border Background="#99d9d8" Height="20" Width="50" Margin="140,210,464,68">
                <TextBlock Text="OR" FontSize="12" FontFamily="Cascadia Mono" FontWeight="Bold" Foreground="#515151" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <Border Height="30" Width="200" Background="White" BorderThickness="1" CornerRadius="3" Margin="65,220,389,10" >
                <StackPanel HorizontalAlignment="Center">
                    <Image Source="/Images/ICONS/GOOGLE.jpg" Margin="5,3,0,0"  Height="20" Width="20" HorizontalAlignment="Left"/>
                    <TextBlock Text="Sign up with Google" FontSize="12" FontFamily="Cascadia Mono" Margin="30,-18,0,0" FontWeight="Bold" Foreground="Black" Width="150" Height="13" />
                </StackPanel>
            </Border>
            <StackPanel Margin="0,0,-80,0">
                <TextBlock Text="Don't have an account?" Height="12" Width="140" Margin="-450,300,0,0" FontSize="10" FontFamily="Cascadia Mono" FontWeight="Bold" Foreground="Black"/>
                <Button Content="Sign Up" Command="{Binding ExecuteGoToLogin}" Width="50" Height="20" Margin="-250,-17,0,0" FontSize="10" FontFamily="Cascadia Mono" FontWeight="Bold" Foreground="Blue" Background="Transparent" BorderThickness="0"/>
            </StackPanel>
            <Button x:Name="SignUpButton"
                  Content="Login"
                  Command= "{Binding SignUpCommand}" 
                  CommandParameter="{Binding ElementName=Passwordbx}" Height="30" 
                  FontFamily="Lucida Console" 
                  FontWeight="Bold" Margin="12,191,336,120">
                <Button.BorderBrush>
                    <SolidColorBrush Color="Blue" Opacity="100"/>
                </Button.BorderBrush>
                <Button.Background>
                    <SolidColorBrush Color="#51b6b6" Opacity="100"/>

                </Button.Background>

            </Button>

        </Grid>
    </Viewbox>
</Window>
