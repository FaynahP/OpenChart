<Window x:Class="OpenChart.View.Dashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenChart.View"
        mc:Ignorable="d"
        Title="Dashboard" Height="450" Width="800">
    <Window.Background>
        <SolidColorBrush Color="#f0f2f2"/>
    </Window.Background>
    <Viewbox Stretch="Uniform">
        <Grid Margin="0,0,0,62">
            <!--TOP BAR-->
            <Border Background="White"  BorderBrush="DimGray" BorderThickness="1" Height="40" Width="1206" VerticalAlignment="Top">

                <StackPanel HorizontalAlignment="Left" Margin="10,0,0,0">
                    <Button  Height="20" Width="50" FontFamily="Gill Sans MT" FontWeight="Regular" HorizontalAlignment="Right" Background="{x:Null}" BorderBrush="{x:Null}" Margin="0,9,-310,0">
                        <TextBlock Text="Logout" TextDecorations="Underline" FontSize="15" FontFamily="Gill Sans MT Condensed" FontWeight="Regular" HorizontalAlignment="Right" />
                    </Button>
                    <Border Background="#9BDBDB" CornerRadius="6" Width="30" Height="30" Margin="0,-25,835,-2">
                        <Image Source="/Images/ICONS/OCTempLogo.png" Height="35" Width="30" />
                    </Border>
                    <TextBlock Text="OpenChart" FontSize="20" FontFamily="Gill Sans MT" FontWeight="Bold" Width="111" Margin="0,-25,675,-2"/>
                </StackPanel>
            </Border>


            <!--NAVIGATION BAR-->
            <Border Background="#dcf4f4" BorderBrush="DimGray" BorderThickness="1" Height="583" Width="150" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="0,0,0,-62" Grid.ColumnSpan="2" Grid.RowSpan="2"/>

            <!--AddButton-->
            <StackPanel Margin="0,55,1055,0">
                <Button Background="#9bdbdb" Height="50" Width="120" BorderThickness="2" BorderBrush="#43989b" Grid.ColumnSpan="2" >
                    <StackPanel>
                        <TextBlock Text="QUICK ADD" FontSize="12" FontFamily="Gill Sans MT" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="30,0,0,0"/>
                        <Image Source="/Images/ICONS/PLUS.png"  Margin="10,-15,0,0" Width="15" HorizontalAlignment="Left"  Grid.Column="1"/>
                    </StackPanel>
                </Button>
            </StackPanel>



            <!--Dashboard-->
            <Border Background="#54b4b4"  Height="40" Width="5" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="3,131,0,0"/>
            <StackPanel Grid.ColumnSpan="2" Margin="-59,0,80,10" Grid.RowSpan="2">
                <Image Source="/Images/ICONS/DASHBOARD.png" Height="20" Width="20" Margin="0,140,1015,-1"/>
                <Button  Command="{Binding DashCommand}" Content="Dashboard"  FontSize="12" FontFamily="Gill Sans MT" FontWeight="UltraBold" BorderThickness="0" HorizontalAlignment="Left" Height="40" Width="148" Margin="60,-28,0,0" BorderBrush="{x:Null}" Background="{x:Null}">


                </Button>
            </StackPanel>
            <!--Medicine-->
            <StackPanel Grid.ColumnSpan="2" Margin="-59,40,80,10" Grid.RowSpan="2">
                <Image Source="/Images/ICONS/MEDICINE.png" Height="50" Width="25" Margin="0,150,1015,-1"/>
                <Button  Command="{Binding MedicineCommand}" Padding="0,0,20,0"  Content="Medicine" FontSize="12" FontFamily="Gill Sans MT" FontWeight="UltraBold" BorderThickness="0" HorizontalAlignment="Left" Height="40" Width="148" Margin="60,-50,0,0" Background="{x:Null}">
                </Button>
            </StackPanel>
            <!--Clients-->
            <StackPanel Grid.ColumnSpan="2" Margin="-59,95,80,10" Grid.RowSpan="2">
                <Image Source="/Images/ICONS/CLIENTS.png" Height="50" Width="25" Margin="0,150,1010,-1"/>
                <Button  Command="{Binding ClientCommand}" Content="Clients" Padding="0,0,25,0" FontSize="12" FontFamily="Gill Sans MT" FontWeight="UltraBold"  BorderThickness="0" HorizontalAlignment="Left" Height="40" Width="148" Margin="60,-50,0,0" Background="{x:Null}">

                </Button>
            </StackPanel>
            <!--Transactions-->
            <StackPanel Grid.ColumnSpan="2" Margin="-59,100,80,10" Grid.RowSpan="2">
                <Image Source="/Images/ICONS/REPORTS.png" Height="50" Width="25" Margin="0,203,1010,-1"/>
                <Button  Command="{Binding TransCommand}" Content="Transactions" Padding="0,0,-10,0" FontSize="12" FontFamily="Gill Sans MT" FontWeight="UltraBold"  BorderThickness="0" HorizontalAlignment="Left" Height="40" Width="148" Margin="60,-50,0,0" Background="{x:Null}">

                </Button>
            </StackPanel>
            <!--Supply Batch-->
            <StackPanel Grid.ColumnSpan="2" Margin="-59,157,80,10" Grid.RowSpan="2">
                <Image Source="/Images/ICONS/SUPPLY BATCH.png" Height="50" Width="25" Margin="0,203,1010,-1"/>
                <Button  Command="{Binding SuBCommand}" Content="Supply Batch" Padding="0,0,-10,0" FontSize="12" FontFamily="Gill Sans MT" FontWeight="UltraBold"  BorderThickness="0" HorizontalAlignment="Left" Height="40" Width="148" Margin="60,-50,0,0" Background="{x:Null}">

                </Button>
            </StackPanel>
            <!--Suppliers-->
            <StackPanel Grid.ColumnSpan="2" Margin="-59,220,76,10" Grid.RowSpan="2">
                <Image Source="/Images/ICONS/SUPPLIER.png" Height="50" Width="25" Margin="0,203,1010,-1"/>
                <Button  Command="{Binding SuppCommand}" Content="Suppliers" FontSize="12" FontFamily="Gill Sans MT" FontWeight="UltraBold"  BorderThickness="0" HorizontalAlignment="Left" Height="40" Width="148" Margin="60,-50,0,0" Background="{x:Null}">

                </Button>
            </StackPanel>
            <!--Logout-->
            <Button Height="20" Width="50" FontFamily="Gill Sans MT Condensed" FontWeight="Regular" HorizontalAlignment="Right" Margin="0,547,1105,-46" Grid.Column="1" Grid.Row="1" Background="{x:Null}" BorderBrush="{x:Null}">
                <TextBlock Text="Logout" TextDecorations="Underline" FontSize="15" FontFamily="Gill Sans MT Condensed" FontWeight="Regular" HorizontalAlignment="Right" Margin="0,0,0,0"/>
            </Button>

            <!--DASHBOARD CONTENT-->
            <TextBlock Text="{Binding CurrentUser.First_Name, StringFormat='Welcome, {0}!'}" FontSize="55"   FontFamily="Century Gothic" FontWeight="ExtraBold" Height="60"  Grid.Column="1" Margin="170,37,617,436"/>

            <Border Background="#dcf4f4" Margin="169,120,49,234" VerticalAlignment="Top" BorderThickness="3" BorderBrush="#aac7c7" CornerRadius="5" Grid.Column="1" >
                <StackPanel>
                    <Image Source="/Images/ICONS/MASCOTSDRUGS.png" Height="157" Width="150" Grid.Column="1" Margin="6,15,678,21" />
                    <TextBlock Text="TOTAL CLIENTS" FontSize="18" FontFamily="Century Gothic" FontWeight="Bold" Margin="33,-330,-20,10" Height="30" Width="145"/>
                    <TextBlock Text="TOTAL SUPPLIES" FontSize="18" FontFamily="Century Gothic" FontWeight="Bold" Margin="573,-330,-15,10" Height="30" Width="145"/>
                    <Line X1="-90" Y1="90" X2="-90" Y2="-90" Stroke="#b6bfbd" StrokeThickness="1" Margin="400,-95,-20,10" Grid.Column="1"/>
                    <Border Background="#9bdbdb" BorderBrush="#54b4b4" Height="130" Width="250" Margin="10,-170,-20,10" CornerRadius="3" BorderThickness="2">
                        <TextBlock Text="NUM" FontSize="18" FontFamily="Century Gothic" FontWeight="Bold"  Height="30" Margin="101,49,96,47"/>

                    </Border>
                    <Border Background="#9bdbdb" BorderBrush="#54b4b4" Height="130" Width="250" Margin="550,-170,-20,10" CornerRadius="3" BorderThickness="2">
                        <TextBlock Text="NUM" FontSize="18" FontFamily="Century Gothic" FontWeight="Bold"  Height="30" Margin="101,49,96,47"/>

                    </Border>
                </StackPanel>
            </Border>
           
            <Border x:Name="SUPPLYGRID" Background="#dcf4f4" Margin="169,370,49,75" Height="115" BorderThickness="2" BorderBrush="#aac7c7" CornerRadius="5" Grid.Column="1">
                <ListView ItemsSource="{Binding supplyBatchList}" SelectedItem="{Binding SelectedSuB}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Medicine ID" DisplayMemberBinding="{Binding suBName}" Width="210"/>
                            <GridViewColumn Header="Name" DisplayMemberBinding="{Binding suBName}" Width="220"/>
                            <GridViewColumn Header="Category" DisplayMemberBinding="{Binding suBName}" Width="220"/>
                            <GridViewColumn Header="Batch ID" DisplayMemberBinding="{Binding suBName}" Width="210"/>
                        </GridView>
                    </ListView.View>
                    <ListView.Resources>
                        <Style TargetType="GridViewColumnHeader">
                            <Setter Property="Background" Value="#9bdbdb"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="FontFamily" Value="Century Gothic"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="#dcf4f4"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="FontFamily" Value="Century Gothic"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="Regular"/>
                        </Style>
                        <Style TargetType="ListView">
                            <Setter Property="Background" Value="#dcf4f4"/>
                            <Setter Property="BorderBrush" Value="#aac7c7"/>
                        </Style>
                    </ListView.Resources>
                </ListView>
            </Border>
           
            <Border x:Name="CLIENTGRID"  Background="#dcf4f4" Margin="169,497,49,-59" Height="115" BorderThickness="2" BorderBrush="#aac7c7" CornerRadius="5" Grid.Column="1" Grid.RowSpan="2">
                <ListView ItemsSource="{Binding supplyBatchList}" SelectedItem="{Binding SelectedSuB}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Client ID" DisplayMemberBinding="{Binding suBName}" Width="210"/>
                            <GridViewColumn Header="Last Name" DisplayMemberBinding="{Binding suBName}" Width="220"/>
                            <GridViewColumn Header="First Name" DisplayMemberBinding="{Binding suBName}" Width="220"/>
                            <GridViewColumn Header="Status" DisplayMemberBinding="{Binding suBName}" Width="210"/>

                        </GridView>
                    </ListView.View>
                    <ListView.Resources>
                        <Style TargetType="GridViewColumnHeader">
                            <Setter Property="Background" Value="#9bdbdb"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="FontFamily" Value="Century Gothic"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="#dcf4f4"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="FontFamily" Value="Century Gothic"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="Regular"/>
                        </Style>
                        <Style TargetType="ListView">
                            <Setter Property="Background" Value="#dcf4f4"/>
                            <Setter Property="BorderBrush" Value="#aac7c7"/>
                        </Style>
                    </ListView.Resources>
                </ListView>
            </Border>
            <TextBlock Text="Recently Added" FontSize="15" FontFamily="Century Gothic" FontWeight="Bold" Foreground="#3a3a3a" Grid.Column="1" Margin="170,335,618,184"/>


        </Grid>

    </Viewbox>

</Window>
