<Window x:Class="OpenChart.View.InvHandlers.TransactionsEdit"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenChart.View.InvHandlers"
        mc:Ignorable="d"
        Title="TransactionsEdit" Height="450" Width="450">
    <Window.Background>
        <SolidColorBrush Color="#f0f2f2"/>
    </Window.Background>
    <Viewbox Stretch="Uniform">
        <Grid Margin="0,0,0,0">
            <!--EDIT:CLIENT-->
            <StackPanel  VerticalAlignment="Top" HorizontalAlignment="Left" Grid.Column="1">
                <Border Background="#dcf4f4" Height="455" Width="474" BorderThickness="1" BorderBrush="#aac7c7">
                    <StackPanel>
                        <Border Background="#ebffff" Height= "375" Width="450" Margin="0,60,0,0">
                            <StackPanel Margin="0,-20,0,0">
                                <Border Background="#ebffff" Height= "375" Width="450" Margin="0,30,0,0">
                                    <StackPanel Margin="0,-20,0,0">
                                        <StackPanel Margin="20,10,10,10" HorizontalAlignment="Left">
                                            <TextBlock Text="User ID" FontSize="15" FontFamily="Gill Sans MT" FontWeight="UltraBold" Height="20" Margin="-50,50,0,0" Width="100"/>
                                            <TextBlock Text="Client ID" FontSize="15" FontFamily="Gill Sans MT" FontWeight="UltraBold" Height="20"  Margin="-50,50,0,0" Width="100"/>
                                            <TextBlock Text="Medicine ID" FontSize="15" FontFamily="Gill Sans MT" FontWeight="UltraBold" Height="20"  Margin="-50,50,0,0" Width="100"/>
                                            <TextBlock Text="Transaction Date" FontSize="15" FontFamily="Gill Sans MT" FontWeight="UltraBold" Height="20"  Margin="0,50,0,0" Width="150"/>
                                        </StackPanel>
                                        <StackPanel Margin="200,-242,10,10" HorizontalAlignment="Left">
                                            <TextBox Height="20" Width="200"/>
                                            <TextBox Height="20" Width="200" Margin="0,50,0,0"/>
                                            <TextBox Height="20" Width="200" Margin="0,50,0,0"/>
                                            <DatePicker Height="25" Width="200" Margin="0,50,0,0"/>
                                        </StackPanel>
                                        <Button Content="SAVE" Height="40" Width="90" HorizontalAlignment="Right" Margin="0,20,160,0" Background="#9bdbdb" BorderThickness="1" BorderBrush="#43989b" FontFamily="Gill Sans MT"  FontWeight="Bold"/>
                                        <Button Content="DELETE" Height="40" Width="90" HorizontalAlignment="Right" Margin="0,-40,50,0" Background="#db9b9b" BorderThickness="1" BorderBrush="#43989b" FontFamily="Gill Sans MT"  FontWeight="Bold"/>
                                    </StackPanel>

                                </Border>
                                <Button Content="ADD SUPPLY" Height="40" Width="90" HorizontalAlignment="Right" Margin="0,10,160,0" Background="#9bdbdb" BorderThickness="1" BorderBrush="#43989b" FontFamily="Gill Sans MT"  FontWeight="Bold"/>
                                <Button Content="CANCEL" Height="40" Width="90" HorizontalAlignment="Right" Margin="0,-40,50,0" Background="#c1f0f0" BorderThickness="1" BorderBrush="#43989b" FontFamily="Gill Sans MT"  FontWeight="Bold"/>
                            </StackPanel>

                        </Border>
                        <Border  Background="#9bdbdb" Height= "45" Width="474" Margin="-1,-825,0,0" BorderThickness="1" BorderBrush="#aac7c7">
                            <Grid>
                                <TextBlock Text="EDIT TRANSACTIONS" FontFamily="Century Gothic" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <Button Content="X" FontSize="20" FontFamily="Century Gothic" FontWeight="Bold" Foreground="#0b8a8a" Margin="420,0,0,0" Height="40" Width="20" Background="{x:Null}" BorderBrush="{x:Null}"/>
                            </Grid>

                        </Border>

                    </StackPanel>

                </Border>
            </StackPanel>
        </Grid>
    </Viewbox>
</Window>
