<Window x:Class="OpenChart.View.Supply_QuickAdd"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenChart.View"
        mc:Ignorable="d"
        Title="Supply_QuickAdd" WindowState="Maximized" WindowStyle="SingleBorderWindow" Height="450" Width="450">
     <Window.Background>
     <SolidColorBrush Color="#f0f2f2"/>
 </Window.Background>
 <Viewbox Stretch="Uniform">
     <Grid>        
         <!--QUICK ADD CONTENT:SUPPLY-->
         <StackPanel  VerticalAlignment="Top" HorizontalAlignment="Left" Grid.Column="1">
             <Border Background="#dcf4f4" Height="451" Width="474" BorderThickness="1" BorderBrush="#aac7c7">
                    <StackPanel>
                        <Border Background="#ebffff" Height= "375" Width="450" Margin="0,60,0,0">
                            <StackPanel Margin="0,-20,0,0">
                                <StackPanel Margin="20,10,10,10" HorizontalAlignment="Left">
                                    <TextBlock Text="Name" FontSize="15" FontFamily="Gill Sans MT" FontWeight="UltraBold" Height="20" Margin="0,30,0,0" Width="100"/>
                                    <TextBlock Text="Category" FontSize="15" FontFamily="Gill Sans MT" FontWeight="UltraBold" Height="20"  Margin="0,30,0,0" Width="100"/>
                                    <TextBlock Text="Batch No." FontSize="15" FontFamily="Gill Sans MT" FontWeight="UltraBold" Height="20"  Margin="0,30,0,0" Width="100"/>
                                    <TextBlock Text="Supplier ID" FontSize="15" FontFamily="Gill Sans MT" FontWeight="UltraBold" Height="20"  Margin="0,30,0,0" Width="100"/>
                                    <TextBlock Text="Stocks" FontSize="15" FontFamily="Gill Sans MT" FontWeight="UltraBold" Height="20" Margin="0,30,0,0"  Width="100"/>
                                    <TextBlock Text="Expiry Date" FontSize="15" FontFamily="Gill Sans MT" FontWeight="UltraBold" Height="20"  Margin="0,30,0,0" Width="100"/>
                                </StackPanel>
                                <StackPanel Margin="200,-281,10,10" HorizontalAlignment="Left">
                                    <TextBox Height="20" Width="200"/>
                                    <ComboBox Height="20" Width="200" Margin="0,30,0,0" Background="White"/>
                                    <TextBox Height="20" Width="200" Margin="0,30,0,0"/>
                                    <TextBox Height="20" Width="200" Margin="0,30,0,0"/>
                                    <TextBox Height="20" Width="200" Margin="0,30,0,0"/>
                                    <DatePicker Height="25" Width="200" Margin="0,30,0,0"/>
                                </StackPanel>
                                <Button Content="ADD SUPPLY" Height="40" Width="90" HorizontalAlignment="Right" Margin="0,10,160,0" Background="#9bdbdb" BorderThickness="1" BorderBrush="#43989b" FontFamily="Gill Sans MT"  FontWeight="Bold"/>
                                <Button Content="CANCEL" Height="40" Width="90" HorizontalAlignment="Right" Margin="0,-40,50,0" Background="#c1f0f0" BorderThickness="1" BorderBrush="#43989b" FontFamily="Gill Sans MT"  FontWeight="Bold"/>
                            </StackPanel>

                        </Border>
                        <Button Content="CLIENT" FontSize="18" FontFamily="Gill Sans MT" FontWeight="UltraBold" Background="{x:Null}" Height= "45" Width="158" Margin="-314,-825,0,0" BorderThickness="1" BorderBrush="#aac7c7"/>

                        <Button Content="SUPPLY" Background="#FF9BDBDB" FontSize="18" FontFamily="Gill Sans MT" FontWeight="UltraBold" Height= "45" Width="158" Margin="0.5,-825,0,0" BorderThickness="1" BorderBrush="#aac7c7"/>

                        <Button Background="#dcf4f4" Content="SUPPLIER" FontSize="18" FontFamily="Gill Sans MT" FontWeight="UltraBold" Height= "45" Width="158" Margin="314,-826,0,0" BorderThickness="1" BorderBrush="#aac7c7"/>

                    </StackPanel>




                </Border>
         </StackPanel>
     </Grid>
 </Viewbox>
</Window>
